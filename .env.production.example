# ============================================================
# PRODUCTION ENVIRONMENT VARIABLES — add real values in Vercel
# ============================================================

# Supabase — https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Stripe — https://dashboard.stripe.com/apikeys (use live keys for prod)
STRIPE_SECRET_KEY=sk_live_your_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_secret_here
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_your_key_here
NEXT_PUBLIC_STRIPE_PRICE_STARTER=price_starter_id_here
NEXT_PUBLIC_STRIPE_PRICE_PROFESSIONAL=price_professional_id_here
NEXT_PUBLIC_STRIPE_PRICE_ENTERPRISE=price_enterprise_id_here

# Site URL (your production domain)
NEXT_PUBLIC_SITE_URL=https://www.flowstart.it

# Formspree — https://formspree.io
NEXT_PUBLIC_FORMSPREE_ID=your_formspree_form_id_here

# Calendly — your booking page URL
NEXT_PUBLIC_CALENDLY_URL=https://calendly.com/your-username/your-event

# n8n onboarding webhook
N8N_WEBHOOK_URL=https://your-n8n-instance.com/webhook/onboarding
N8N_CALLBACK_SECRET=your_32_char_random_secret_here

# Resend — transactional email https://resend.com/api-keys
RESEND_API_KEY=re_your_resend_api_key_here

# VAPI — voice agent platform https://vapi.ai
VAPI_API_KEY=your_vapi_api_key_here
VAPI_WEBHOOK_SECRET=your_vapi_webhook_secret_here
